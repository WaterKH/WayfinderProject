@using WayfinderProject.Domain

<div class="wayfinder-sub-nav-bar" style="@CustomStyle">
    @if (IsFocusEnabled && !string.IsNullOrEmpty(FocusOption))
    {
        @RenderOption(FocusOption, "margin-right: 25px;")
        <span class="wayfinder-divider"></span>
    }

    @if (Options != null)
    {
        @foreach (var option in Options)
        {
            @if (!IsFocusEnabled || option != FocusOption)
            {
                @RenderOption(option)
            }
        }
    }
</div>

<div class="wayfinder-sub-nav-bar-border"></div>

@code {
    [Parameter] public IEnumerable<string> Options { get; set; } = Array.Empty<string>();
    [Parameter] public string CustomStyle { get; set; } = string.Empty;
    [Parameter] public string StartingOption { get; set; } = string.Empty;
    [Parameter] public string FocusOption { get; set; } = string.Empty;
    [Parameter] public bool IsFocusEnabled { get; set; } = true;
    [Parameter] public bool DisplayIcons { get; set; } = true;
    [Parameter] public bool InvertBackgroundColor { get; set; } = false;
    [Parameter] public EventCallback<string> OnOptionSelected { get; set; }

    private string CurrentOption { get; set; } = string.Empty;

    private RenderFragment RenderOption(string option, string extraStyle = "") => __builder =>
    {
        var isActive = CurrentOption == option;
        var containerClass = isActive ? "wayfinder-container-active" : "wayfinder-container";
        var optionClass = isActive ? "wayfinder-option-active" : "wayfinder-option";
        var bgStyle = InvertBackgroundColor ? "background-color: white;" : "";

        <div class="@containerClass" @onclick="() => Select(option)" style="@(extraStyle + bgStyle)">
            <div class="@optionClass" style="max-width: 200px; @bgStyle">
                @if (DisplayIcons)
                {
                    <img src="@Utilities.GetImage(option)" class="wayfinder-nav-icon" />
                }
                @option
            </div>
        </div>
    };

    protected override void OnParametersSet()
    {
        if (CurrentOption != StartingOption && !string.IsNullOrEmpty(StartingOption))
        {
            CurrentOption = StartingOption;
        }
    }

    private async Task Select(string option)
    {
        if (CurrentOption == option) return;

        CurrentOption = option;

        if (OnOptionSelected.HasDelegate)
        {
            await OnOptionSelected.InvokeAsync(option);
        }
    }
}


