@typeparam TItem where TItem : WayfinderProject.Domain.Models.BaseMemoryArchiveData<ScriptLine>
@using WayfinderProject.Domain.Models.MemoryArchive
@using WayfinderProject.Domain.Models.MemoryArchive.SubData


<div class="row">
    <div class="col-md-5">
        <SubNavBar Options="@(new List<string> { "Details", "Dialogue" })" 
                    OnOptionSelected="UpdateCurrentSubOption" 
                    StartingOption="@CurrentSubOption" 
                    CustomStyle="margin-top: -15px;" InvertBackgroundColor="true" />

        <div class="expansion-content-card">
            @if (CurrentSubOption == "Details")
            {
                <div class="details-pane">
                    <h3>@Item.Name</h3>

                    @foreach (var detail in GetDetails())
                    {
                        <div class="mt-4">
                            <h3 class="@(detail.Color)-color">
                                <img src="images/icons/@(detail.Icon).png" class="detail-icon" /> @detail.Title
                            </h3>
                            <label>@string.Join(", ", detail.Data)</label>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="dialogue-pane">
                    <div class="wayfinder-search">
                        <span class="wayfinder-search-icon material-icons">search</span>
                        <input id="dialogue-search" 
                                class="custom-input"
                                placeholder="Search Dialogue..."
                                @oninput="@(async e => { searchValue = e.Value?.ToString() ?? ""; await SearchDialogue(); })" />
                    </div>

                    <div class="character-filter text-center mb-2">
                        @foreach (var name in characters)
                        {
                            <div class="@(currentCharacter == name ? "character-option-selected" : "character-option")" 
                                    @onclick="() => SelectCharacter(name)">@name</div>
                        }
                    </div>
                    <hr />
                    <div class="dialogue-table-container">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th style="width: 125px; background: transparent;">Character</th>
                                    <th style="background: transparent;">Line</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in dialogue.OrderBy(line => line.Order))
                                {
                                    <tr>
                                        <td><strong>@line.Person</strong></td>
                                        <td>@line.Line</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="col-md-7">
        <iframe src="@EmbedUrl" 
                class="video-embed"
                sandbox="allow-forms allow-scripts allow-pointer-lock allow-same-origin allow-presentation"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; compute-pressure"
                allowfullscreen>
        </iframe>
    </div>
</div>


@code {
    [Parameter] public TItem Item { get; set; } = default!;
    [Parameter] public Func<Task>? GenerateShareLink { get; set; }

    public string CurrentSubOption { get; set; } = "Details";

    private string searchValue = "", currentCharacter = "";
    private List<ScriptLine> dialogue = new();
    private List<string> characters = new();

    private string EmbedUrl => $"https://www.youtube-nocookie.com/embed/{GetVideoId(Item.Link)}?rel=0&modestbranding=1";

    protected override void OnInitialized() => ResetDialogue();

    private void ResetDialogue()
    {
        dialogue = Item.SubData.ToList();
        characters = dialogue.Select(x => x.Person).Distinct().ToList();
    }

    private string GetVideoId(string url)
    {
        if (string.IsNullOrEmpty(url)) return "";
        // Handles both watch?v=ID and youtu.be/ID
        var uri = new Uri(url);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        return query["v"] ?? uri.Segments.Last();
    }

    public async Task UpdateCurrentSubOption(string option)
    {
        CurrentSubOption = option;
        StateHasChanged();
    }

    public async Task SearchDialogue()
    {
        var query = Item.SubData.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchValue))
            query = query.Where(x => x.Line.Contains(searchValue, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(currentCharacter))
            query = query.Where(x => x.Person == currentCharacter);

        dialogue = query.ToList();
        StateHasChanged();
    }

    public async Task SelectCharacter(string name)
    {
        currentCharacter = (currentCharacter == name) ? "" : name;
        await SearchDialogue();
    }

    private IEnumerable<(string Title, string Color, string Icon, IEnumerable<string> Data)> GetDetails() => new[]
    {
        (Title: "Game", Color: "game", Icon: "games_gray", Data: (IEnumerable<string>)[Item.Game]),
        (Title: "Worlds", Color: "world", Icon: "worlds", Data: (IEnumerable<string>)Item.Worlds),
        (Title: "Characters", Color: "character", Icon: "characters", Data: (IEnumerable<string>)Item.Characters),
        (Title: "Areas", Color: "area", Icon: "areas", Data: (IEnumerable<string>)Item.Areas),
        (Title: "Music", Color: "music", Icon: "music", Data: (IEnumerable<string>)Item.Music)
    };
}
