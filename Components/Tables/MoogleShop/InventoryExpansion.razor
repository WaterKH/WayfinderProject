@typeparam TItem where TItem : WayfinderProject.Domain.Models.MoogleShop.Inventory
@using WayfinderProject.Domain
@using WayfinderProject.Domain.Models.MoogleShop
@using WayfinderProject.Domain.Models.MoogleShop.SubData


<div class="row">
    <div class="col-md-5">
        <div class="expansion-content-card">
            <div class="details-pane">
                <h3>@Item.Name</h3>

                @foreach (var detail in GetDetails())
                {
                    <div class="mt-4">
                        <h3 class="@(detail.Color)-color">
                            <img src="images/icons/@(detail.Icon).png" class="detail-icon" /> @detail.Title
                        </h3>
                        <label>@string.Join(", ", detail.Data)</label>
                    </div>
                }

                <div class="mt-4">
                    <h3>
                        <img src="images/icons/game_hearts/@(Utilities.GetCodeForGame(Item.Game)).png" class="info-detail-icon" /> Information
                    </h3>
                    <label class="font-weight-700">@Item.Description</label>
                </div>

                @if (!string.IsNullOrEmpty(Item.AdditionalInformation))
                {
                    <div class="mt-4">
                        <label class="font-weight-700">@Item.AdditionalInformation</label>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (Item.SubData.Count > 0)
    {
        <div class="col-md-7">
            <div class="expansion-content-card">
                <div class="dialogue-pane">
                
                    <hr />
                    <div class="dialogue-table-container">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th style="background: transparent;">Enemy</th>
                                    <th style="background: transparent;">Drop Rate</th>
                                    <th style="background: transparent;">Additional Information</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var data in Item.SubData.OrderByDescending(data => data.DropRate))
                                {
                                    <tr>
                                        <td><strong>@data.EnemyName</strong></td>
                                        <td>@data.DropRate</td>
                                        <td>@data.AdditionalInformation</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-md-2"></div>

        <div class="col-md-4">
            <img class="image-container" src="images/MS.png" />
        </div>
    }
</div>


@code {
    [Parameter] public TItem Item { get; set; } = default!;
    [Parameter] public Func<Task>? GenerateShareLink { get; set; }

    private IEnumerable<(string Title, string Color, string Icon, IEnumerable<string> Data)> GetDetails() => new[]
    {
        (Title: "Game", Color: "game", Icon: "games_gray", Data: (IEnumerable<string>)[Item.Game]),
        (Title: "Categories", Color: "area", Icon: "areas", Data: (IEnumerable<string>)[Item.Category]),
        (Title: "Costs", Color: "world", Icon: "ability", Data: (IEnumerable<string>)[Item.Cost.ToString()]),
        (Title: "Currencies", Color: "world", Icon: "worlds", Data: (IEnumerable<string>)[Item.Currency])
    };
}
